<?xml version="1.0" encoding="utf-8"?>
<!--
  KUKA KR 250 R2700-2  —  Flattened URDF (no xacro dependency)
  =============================================================
  Based on KR 210 R2700-2 with adjusted payload, joint velocities,
  joint 5 limits, and link masses.

  Source: official KUKA datasheet for KR 250 R2700-2
  Kinematic chain:  world → base_link → link_1 → ... → link_6 → flange → tool0
  All joint axes:   Z (0 0 1)
  Mesh paths:       shares kr210_r2700_2 meshes (identical mechanical structure)
  Units:            metres, radians, kg
-->
<robot name="kuka_kr250_r2700_2">

  <!-- ============================================================= -->
  <!-- MATERIALS                                                      -->
  <!-- ============================================================= -->
  <material name="KukaPedestal">
    <color rgba="0.5 0.47 0.38 1.0"/>
  </material>
  <material name="KukaOrange">
    <color rgba="0.96 0.47 0.16 1.0"/>
  </material>

  <!-- ============================================================= -->
  <!-- LINKS                                                          -->
  <!-- ============================================================= -->

  <!-- Fixed world frame -->
  <link name="world"/>

  <!-- Base link  (total robot mass ~1101 kg, redistributed proportionally) -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/kr210_r2700_2/visual/base_link.stl"/>
      </geometry>
      <material name="KukaPedestal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/kr210_r2700_2/collision/base_link.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="237.46"/>
      <inertia ixx="13.88" ixy="0" ixz="0"
               iyy="33.10" iyz="0"
               izz="35.61"/>
    </inertial>
  </link>

  <!-- Link 1 -->
  <link name="link_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/kr210_r2700_2/visual/link_1.stl"/>
      </geometry>
      <material name="KukaOrange"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="../meshes/kr210_r2700_2/collision/link_1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="381.55"/>
      <inertia ixx="60.72" ixy="0" ixz="0"
               iyy="5.92" iyz="0"
               izz="61.52"/>
    </inertial>
  </link>

  <!-- Link 2 -->
  <link name="link_2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/kr210_r2700_2/visual/link_2.stl"/>
      </geometry>
      <material name="KukaOrange"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="../meshes/kr210_r2700_2/collision/link_2.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="243.86"/>
      <inertia ixx="3.65" ixy="0" ixz="0"
               iyy="22.24" iyz="0"
               izz="23.33"/>
    </inertial>
  </link>

  <!-- Link 3 -->
  <link name="link_3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/kr210_r2700_2/visual/link_3.stl"/>
      </geometry>
      <material name="KukaOrange"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="../meshes/kr210_r2700_2/collision/link_3.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="200.02"/>
      <inertia ixx="0.17" ixy="0" ixz="0"
               iyy="1.43" iyz="0"
               izz="1.46"/>
    </inertial>
  </link>

  <!-- Link 4 -->
  <link name="link_4">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/kr210_r2700_2/visual/link_4.stl"/>
      </geometry>
      <material name="KukaOrange"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="../meshes/kr210_r2700_2/collision/link_4.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="44.57"/>
      <inertia ixx="0.21" ixy="0" ixz="0"
               iyy="0.13" iyz="0"
               izz="0.23"/>
    </inertial>
  </link>

  <!-- Link 5 -->
  <link name="link_5">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/kr210_r2700_2/visual/link_5.stl"/>
      </geometry>
      <material name="KukaOrange"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="../meshes/kr210_r2700_2/collision/link_5.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="17.86"/>
      <inertia ixx="0.012" ixy="0" ixz="0"
               iyy="0.012" iyz="0"
               izz="0.015"/>
    </inertial>
  </link>

  <!-- Link 6 -->
  <link name="link_6">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/kr210_r2700_2/visual/link_6.stl"/>
      </geometry>
      <material name="KukaOrange"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="../meshes/kr210_r2700_2/collision/link_6.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="6.94"/>
      <inertia ixx="0.039" ixy="0" ixz="0"
               iyy="0.039" iyz="0"
               izz="0.051"/>
    </inertial>
  </link>

  <!-- Flange (empty link — EEF attachment point) -->
  <link name="flange"/>

  <!-- ROS-Industrial base frame -->
  <link name="base"/>

  <!-- Tool0 (KUKA $TOOL coordinate system) -->
  <link name="tool0"/>

  <!-- ============================================================= -->
  <!-- JOINTS                                                         -->
  <!-- ============================================================= -->

  <!-- world → base_link (fixed) -->
  <joint name="world-base_link" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Joint 1:  base_link → link_1
       limits: ±185° = ±3.22886 rad
       velocity: 105°/s = 1.83260 rad/s  (KR210: 120°/s) -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0" rpy="-3.14159265 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.22885912" upper="3.22885912"
           velocity="1.83259571" effort="8500"/>
  </joint>

  <!-- Joint 2:  link_1 → link_2
       limits: -140° .. -5° = -2.44346 .. -0.08727 rad
       velocity: 107°/s = 1.86750 rad/s  (KR210: 115°/s) -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0.33 0 -0.645" rpy="1.57079633 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.44346095" upper="-0.08726646"
           velocity="1.86750422" effort="10400"/>
  </joint>

  <!-- Joint 3:  link_2 → link_3
       limits: -120° .. +168° = -2.09440 .. 2.93215 rad
       velocity: 107°/s = 1.86750 rad/s  (KR210: 112°/s) -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="1.15 0 0" rpy="0 0 -1.57079633"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.09439510" upper="2.93215314"
           velocity="1.86750422" effort="8200"/>
  </joint>

  <!-- Joint 4:  link_3 → link_4
       limits: ±350° = ±6.10865 rad
       velocity: 170°/s = 2.96706 rad/s  (KR210: 179°/s) -->
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0.115 0 0" rpy="1.57079633 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.10865238" upper="6.10865238"
           velocity="2.96705973" effort="2700"/>
  </joint>

  <!-- Joint 5:  link_4 → link_5
       limits: ±122.5° = ±2.13802 rad  (KR210: ±125°)
       velocity: 129°/s = 2.25147 rad/s  (KR210: 172°/s) -->
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 -1.22" rpy="-1.57079633 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.13802830" upper="2.13802830"
           velocity="2.25147474" effort="1700"/>
  </joint>

  <!-- Joint 6:  link_5 → link_6
       limits: ±350° = ±6.10865 rad
       velocity: 206°/s = 3.59538 rad/s  (KR210: 220°/s) -->
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 0 0" rpy="1.57079633 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.10865238" upper="6.10865238"
           velocity="3.59537810" effort="950"/>
  </joint>

  <!-- base_link → base (ROS-Industrial $ROBROOT, fixed) -->
  <joint name="base_link-base" type="fixed">
    <parent link="base_link"/>
    <child link="base"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- link_6 → flange (EEF attachment, fixed) -->
  <joint name="joint_6-flange" type="fixed">
    <parent link="link_6"/>
    <child link="flange"/>
    <origin xyz="0 0 -0.215" rpy="0 1.57079633 0"/>
  </joint>

  <!-- flange → tool0 (KUKA $TOOL, fixed) -->
  <joint name="flange-tool0" type="fixed">
    <parent link="flange"/>
    <child link="tool0"/>
    <origin xyz="0 0 0" rpy="0 1.57079633 0"/>
  </joint>

</robot>
